---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';

const SHOW_HOMEPAGE_CONTENT = false;
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main class="product-page">
			{
				SHOW_HOMEPAGE_CONTENT && (
					<>
						<section class="product-hero">
							<div class="hero-heading">
								<h1>A playground for infinite imagination</h1>
							</div>
							<div class="hero-content">
								<div class="hero-copy">
									<p class="hero-kicker">Scatter the tiles. Unlock the playground.</p>
									<p>
										Transform any space into an interactive, screen-free gaming console. Just scatter
										the smart tiles across a floor or table and let the play begin!
									</p>
									<p class="hero-status">Product Coming Soon</p>
									<a class="hero-link" href="/play-tiles/" aria-label="Try the games in the Games tab">
										Try the games
										<span aria-hidden="true">↗</span>
									</a>
								</div>
								<figure class="hero-visual">
									<img
										src="/images/tikatiles-homepage-tile.png"
										alt="A rendered TikaTiles smart tile with illuminated display pixels"
										width="1800"
										height="1200"
									/>
								</figure>
							</div>
							<figure class="hero-video">
								<video
									src="/images/master_tile_4side_spin_12fps_start1.mp4"
									aria-label="Rotating TikaTiles smart tile render"
									muted
									loop
									playsinline
									controls
									preload="metadata"
								></video>
							</figure>
						</section>

						<section class="features-section" aria-label="TikaTiles features">
							<h2>The Features</h2>
							<ul class="feature-list">
								<li>
									<strong>Play Anywhere</strong>
									<p>100% wireless and standalone. No mats, tracks, or screens required.</p>
								</li>
								<li>
									<strong>Smart Spatial Awareness</strong>
									<p>
										The tiles talk to each other. They instantly map their relative positions,
										knowing exactly how you arrange and connect them.
									</p>
								</li>
								<li>
									<strong>Endless Games</strong>
									<p>
										Play high-energy games like Whack-a-Mole and Memory, or place the tiles to solve
										math equations and spatial puzzles.
									</p>
								</li>
								<li>
									<strong>Learn Through Touch</strong>
									<p>
										Open-ended play that introduces physical computing, eventually letting kids
										program their own custom rules.
									</p>
								</li>
							</ul>
						</section>
						<section class="coming-grid" aria-label="Coming soon details">
							<article>
								<p class="card-label">Product</p>
								<h2>Tiles are in development</h2>
								<p>
									The physical tile system is being prototyped now. More product images, videos, and
									details will be added as the hardware form factor matures.
								</p>
							</article>
							<article>
								<p class="card-label">Images</p>
								<h2>Available soon</h2>
								<p>
									High-quality product renders and prototype photos will live here once the design is
									ready to share.
								</p>
							</article>
							<article>
								<p class="card-label">Videos</p>
								<h2>Available soon</h2>
								<p>
									Gameplay demos, setup videos, and hardware progress clips will be added as the tiles
									move closer to product testing.
								</p>
							</article>
						</section>
					</>
				)
			}
		</main>
		<Footer />
	</body>
</html>

<style>
	.product-page {
		width: min(1180px, calc(100% - (var(--page-gutter) * 2)));
		max-width: none;
		padding-top: clamp(2rem, 6vw, 5rem);
	}

	.product-hero {
		display: grid;
		gap: clamp(1.6rem, 4vw, 3rem);
	}

	.hero-heading {
		max-width: 1120px;
	}

	.hero-copy {
		max-width: 700px;
	}

	.hero-content {
		display: grid;
		grid-template-columns: minmax(520px, 1.05fr) minmax(260px, 0.6fr);
		gap: clamp(1.5rem, 4vw, 3.5rem);
		align-items: start;
	}

	.eyebrow,
	.card-label {
		margin: 0 0 0.75rem;
		color: var(--accent);
		font-size: 0.78rem;
		font-weight: 800;
		letter-spacing: 0.08em;
		text-transform: uppercase;
	}

	.hero-heading h1 {
		max-width: 980px;
		margin-bottom: 0;
		font-size: clamp(3rem, 6.5vw, 5.8rem);
		line-height: 0.95;
		text-wrap: balance;
	}

	.hero-kicker {
		margin-bottom: 0.85rem;
		color: rgb(var(--black));
		font-size: clamp(1rem, 1.8vw, 1.25rem);
		font-weight: 900;
		letter-spacing: 0.08em;
		text-transform: uppercase;
	}

	.hero-status {
		margin: 1rem 0 0;
		color: rgb(var(--black));
		font-size: 0.95rem;
		font-weight: 900;
		letter-spacing: 0.08em;
		text-transform: uppercase;
	}

	.hero-copy p {
		max-width: 640px;
		color: rgb(var(--gray-dark));
		font-size: clamp(1.05rem, 2vw, 1.3rem);
		line-height: 1.55;
		text-indent: 0;
	}

	.hero-link {
		display: inline-flex;
		align-items: center;
		gap: 0.45rem;
		justify-content: center;
		min-height: 46px;
		margin-top: 1rem;
		padding: 0 1.15rem;
		border: 1px solid rgb(var(--black));
		border-radius: 999px;
		background: rgb(var(--black));
		color: var(--page-bg);
		font-weight: 800;
		text-decoration: none;
	}

	.hero-link span {
		font-size: 1.1em;
		line-height: 1;
		transform: translateY(-1px);
	}

	.hero-link:hover {
		color: var(--page-bg);
	}

	.hero-visual {
		justify-self: end;
		margin: -2.25rem 0 0;
		width: min(100%, 620px);
	}

	.hero-visual img {
		display: block;
		width: 100%;
		aspect-ratio: 3 / 2;
		object-fit: cover;
		object-position: center top;
		border-radius: 8px;
		box-shadow: var(--box-shadow);
	}

	.hero-video {
		width: min(760px, 100%);
		margin: clamp(1.5rem, 4vw, 2.5rem) 0 0;
	}

	.hero-video video {
		display: block;
		width: 100%;
		aspect-ratio: 16 / 9;
		object-fit: cover;
		object-position: center;
		border-radius: 8px;
		box-shadow: var(--box-shadow);
	}

	.features-section {
		width: min(860px, 100%);
		margin-top: clamp(2.5rem, 6vw, 5rem);
	}

	.features-section h2 {
		margin-bottom: 1rem;
	}

	.feature-list {
		display: grid;
		margin: 0;
		padding: 0;
		list-style: none;
	}

	.feature-list li {
		padding: 1rem 0;
		border-bottom: 1px solid var(--line);
	}

	.feature-list li:last-child {
		padding-bottom: 0;
		border-bottom: 0;
	}

	.feature-list p {
		margin: 0.25rem 0 0;
		color: rgb(var(--gray-dark));
		text-indent: 0;
	}

	.feature-list strong {
		display: block;
		color: rgb(var(--black));
		font-weight: 900;
	}

	.coming-grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 1rem;
		margin-top: clamp(2.5rem, 6vw, 5rem);
	}

	.coming-grid article {
		min-height: 230px;
		padding: 1.25rem;
		border: 1px solid var(--line);
		border-radius: 8px;
		background: var(--surface-raised);
	}

	.coming-grid h2 {
		font-size: 1.35rem;
	}

	.coming-grid p:last-child {
		margin-bottom: 0;
		color: rgb(var(--gray));
		font-size: 1rem;
		line-height: 1.55;
		text-indent: 0;
	}

	@media (max-width: 860px) {
		.hero-content,
		.coming-grid {
			grid-template-columns: 1fr;
		}

		.product-hero {
			min-height: auto;
		}

		.hero-visual img {
			aspect-ratio: 16 / 10;
		}

		.hero-video video {
			aspect-ratio: 16 / 10;
		}

		.hero-visual {
			justify-self: stretch;
			width: 100%;
		}
	}
</style>
