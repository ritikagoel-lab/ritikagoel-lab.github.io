---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main class="product-page">
			<section class="product-hero">
				<div class="hero-heading">
					<h1>A playground for infinite imagination</h1>
				</div>
				<div class="hero-content">
					<div class="hero-copy">
						<p class="hero-kicker">Scatter the tiles. Unlock the playground.</p>
						<p>
							Transform any room into an interactive, screen-free gaming console.
							Just scatter the smart tiles across a floor or table and let the play begin!
						</p>
						<p class="hero-status">Product Coming Soon</p>
						<a class="hero-link" href="/play-tiles/" aria-label="Try the games in the Games tab">
							Try the games
							<span aria-hidden="true">↗</span>
						</a>
					</div>
					<figure class="hero-visual">
						<img src="/images/default-waves.svg" alt="" />
					</figure>
				</div>
			</section>

			<section class="features-section" aria-label="TikaTiles features">
				<div>
					<p class="card-label">The Features</p>
					<h2>One set of tiles, many ways to play.</h2>
				</div>
				<ol class="feature-list">
					<li>
						<h3><span>Play Anywhere</span></h3>
						<p>100% wireless and standalone. No mats, tracks, or screens required.</p>
					</li>
					<li>
						<h3><span>Smart Spatial Awareness</span></h3>
						<p>
							The tiles talk to each other. They instantly map their relative positions,
							knowing exactly how you arrange and connect them.
						</p>
					</li>
					<li>
						<h3><span>Endless Games</span></h3>
						<p>
							Play high-energy games like Whack-a-Mole and Memory, or snap them together
							to solve math equations and spatial puzzles.
						</p>
					</li>
					<li>
						<h3><span>Learn Through Touch</span></h3>
						<p>
							Open-ended play that introduces physical computing, eventually letting kids
							program their own custom rules.
						</p>
					</li>
				</ol>
			</section>

			<section class="coming-grid" aria-label="Coming soon details">
				<article>
					<p class="card-label">Product</p>
					<h2>Tiles are in development</h2>
					<p>
						The physical tile system is being prototyped now. More product images, videos, and
						details will be added as the hardware form factor matures.
					</p>
				</article>
				<article>
					<p class="card-label">Images</p>
					<h2>Available soon</h2>
					<p>
						High-quality product renders and prototype photos will live here once the design is
						ready to share.
					</p>
				</article>
				<article>
					<p class="card-label">Videos</p>
					<h2>Available soon</h2>
					<p>
						Gameplay demos, setup videos, and hardware progress clips will be added as the tiles
						move closer to product testing.
					</p>
				</article>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	.product-page {
		width: min(1180px, calc(100% - (var(--page-gutter) * 2)));
		max-width: none;
		padding-top: clamp(2rem, 6vw, 5rem);
	}

	.product-hero {
		display: grid;
		gap: clamp(2rem, 5vw, 4rem);
		min-height: min(720px, calc(100vh - 180px));
	}

	.hero-heading {
		max-width: 1120px;
	}

	.hero-copy {
		max-width: 560px;
	}

	.hero-content {
		display: grid;
		grid-template-columns: minmax(0, 0.88fr) minmax(360px, 1.12fr);
		gap: clamp(2rem, 6vw, 5rem);
		align-items: start;
	}

	.eyebrow,
	.card-label {
		margin: 0 0 0.75rem;
		color: var(--accent);
		font-size: 0.78rem;
		font-weight: 800;
		letter-spacing: 0.08em;
		text-transform: uppercase;
	}

	.hero-heading h1 {
		max-width: 1100px;
		margin-bottom: 0;
		font-size: clamp(3rem, 7.6vw, 6.5rem);
		line-height: 0.95;
		text-wrap: balance;
	}

	.hero-kicker {
		margin-bottom: 0.85rem;
		color: rgb(var(--black));
		font-size: clamp(1rem, 1.8vw, 1.25rem);
		font-weight: 900;
		letter-spacing: 0.08em;
		text-transform: uppercase;
	}

	.hero-status {
		margin: 1rem 0 0;
		color: rgb(var(--black));
		font-size: 0.95rem;
		font-weight: 900;
		letter-spacing: 0.08em;
		text-transform: uppercase;
	}

	.hero-copy p {
		max-width: 520px;
		color: rgb(var(--gray-dark));
		font-size: clamp(1.05rem, 2vw, 1.3rem);
		line-height: 1.55;
		text-indent: 0;
	}

	.hero-link {
		display: inline-flex;
		align-items: center;
		gap: 0.45rem;
		justify-content: center;
		min-height: 46px;
		margin-top: 1rem;
		padding: 0 1.15rem;
		border: 1px solid rgb(var(--black));
		border-radius: 999px;
		background: rgb(var(--black));
		color: var(--page-bg);
		font-weight: 800;
		text-decoration: none;
	}

	.hero-link span {
		font-size: 1.1em;
		line-height: 1;
		transform: translateY(-1px);
	}

	.hero-link:hover {
		color: var(--page-bg);
	}

	.hero-visual {
		margin: 0;
	}

	.hero-visual img {
		display: block;
		width: 100%;
		aspect-ratio: 4 / 5;
		object-fit: cover;
		border-radius: 8px;
		box-shadow: var(--box-shadow);
	}

	.coming-grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 1rem;
		margin-top: clamp(2rem, 6vw, 5rem);
	}

	.features-section {
		display: grid;
		grid-template-columns: minmax(260px, 0.58fr) minmax(0, 1.42fr);
		gap: clamp(1.5rem, 5vw, 4rem);
		margin-top: clamp(2rem, 6vw, 5rem);
		padding: clamp(1.35rem, 3.5vw, 2.6rem);
		border: 1px solid var(--line);
		border-radius: 8px;
		background: var(--surface-raised);
		box-shadow: var(--box-shadow);
	}

	.features-section h2 {
		max-width: 9ch;
		font-size: clamp(2.25rem, 5vw, 4rem);
		line-height: 0.95;
		letter-spacing: 0;
		text-wrap: balance;
	}

	.feature-list {
		counter-reset: feature;
		display: grid;
		gap: 1.15rem;
		margin: 0;
		padding: 0;
		list-style: none;
	}

	.feature-list li {
		counter-increment: feature;
		display: grid;
		grid-template-columns: 3.25rem minmax(0, 1fr);
		gap: 0.9rem;
		align-items: start;
		padding-bottom: 1.15rem;
		border-bottom: 1px solid var(--line);
	}

	.feature-list li::before {
		content: counter(feature);
		display: grid;
		place-items: center;
		width: 2.5rem;
		aspect-ratio: 1;
		border: 1px solid rgb(var(--black));
		border-radius: 999px;
		background: rgb(var(--black));
		color: var(--page-bg);
		font-size: 1rem;
		font-weight: 900;
		line-height: 1;
	}

	.feature-list li:last-child {
		padding-bottom: 0;
		border-bottom: 0;
	}

	.feature-list h3 {
		margin: 0 0 0.35rem;
		font-size: clamp(1.35rem, 2.7vw, 2.05rem);
		line-height: 1.05;
		letter-spacing: 0;
	}

	.feature-list h3 span {
		display: inline;
		color: rgb(var(--black));
		font-weight: 900;
	}

	.feature-list p {
		margin: 0;
		color: rgb(var(--gray-dark));
		font-size: clamp(1rem, 1.55vw, 1.18rem);
		line-height: 1.5;
		text-indent: 0;
	}

	.coming-grid article {
		min-height: 230px;
		padding: 1.25rem;
		border: 1px solid var(--line);
		border-radius: 8px;
		background: var(--surface-raised);
	}

	.coming-grid h2 {
		font-size: 1.35rem;
	}

	.coming-grid p:last-child {
		margin-bottom: 0;
		color: rgb(var(--gray));
		font-size: 1rem;
		line-height: 1.55;
		text-indent: 0;
	}

	@media (max-width: 860px) {
		.hero-content,
		.features-section,
		.coming-grid {
			grid-template-columns: 1fr;
		}

		.product-hero {
			min-height: auto;
		}

		.hero-visual img {
			aspect-ratio: 16 / 10;
		}
	}
</style>
