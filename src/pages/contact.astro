---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title="Contact | TikaTiles"
			description="Contact information for TikaTiles."
		/>
	</head>
	<body>
		<Header />
		<main class="contact-page">
			<section class="contact-card" aria-labelledby="contact-title">
				<h1 id="contact-title">Ritika Goel</h1>
				<div class="contact-content">
					<img
						class="profile-photo"
						src="/images/ritika-goel.jpeg"
						alt="Ritika Goel"
						width="792"
						height="994"
					/>
					<div class="contact-copy">
						<p>
							Ritika is an embedded systems engineer who loves building playful hardware for kids
							and families. Her engineering journey started in India in 2004, eventually bringing her
							to the University of Pennsylvania. She has spent over a decade designing and optimizing
							consumer electronics at Apple, Intel and Meta among others. Today, TikaTiles is engineered
							from her personal lab in Orange County, California, where she lives with her husband and
							their 8-year-old daughter.
						</p>
					</div>
				</div>
				<div class="contact-links">
					<a href="https://www.linkedin.com/in/ritikagoel23/" target="_blank">LinkedIn</a>
					<a href="mailto:info@tikatiles.com">Email: info@tikatiles.com</a>
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	.contact-page {
		display: grid;
		place-items: center;
		min-height: calc(100vh - 220px);
	}

	.contact-card {
		width: min(980px, 100%);
		padding: clamp(1.5rem, 4vw, 3rem);
		border: 1px solid var(--line);
		border-radius: 8px;
		background: var(--surface-raised);
		box-shadow: var(--box-shadow);
	}

	.contact-content {
		display: grid;
		grid-template-columns: minmax(220px, 0.78fr) minmax(0, 1fr);
		gap: clamp(1.5rem, 4vw, 3rem);
		align-items: start;
	}

	.profile-photo {
		display: block;
		width: 100%;
		aspect-ratio: 4 / 5;
		object-fit: cover;
		object-position: center top;
		border-radius: 8px;
	}

	.contact-card h1 {
		margin-bottom: clamp(1.5rem, 4vw, 2.5rem);
		font-size: clamp(2.25rem, 6vw, 4.25rem);
		line-height: 1;
		text-align: center;
	}

	.eyebrow {
		margin: 0 0 0.75rem;
		color: var(--accent);
		font-size: 0.78rem;
		font-weight: 800;
		letter-spacing: 0.08em;
		text-transform: uppercase;
	}

	.contact-card p {
		color: rgb(var(--gray-dark));
		text-indent: 0;
	}

	.contact-links {
		display: flex;
		flex-wrap: wrap;
		gap: 0.8rem;
		justify-content: center;
		margin-top: clamp(1.75rem, 4vw, 2.75rem);
	}

	.contact-links a {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-height: 42px;
		padding: 0 1rem;
		border: 1px solid rgb(var(--black));
		border-radius: 999px;
		background: rgb(var(--black));
		color: var(--page-bg);
		font-weight: 800;
		text-decoration: none;
	}

	.contact-links a:hover {
		color: var(--page-bg);
	}

	@media (max-width: 760px) {
		.contact-content {
			grid-template-columns: 1fr;
		}

		.profile-photo {
			max-width: 360px;
		}
	}
</style>
