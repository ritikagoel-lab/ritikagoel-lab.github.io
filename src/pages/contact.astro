---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title="Contact | TikaTiles"
			description="Contact information for TikaTiles."
		/>
	</head>
	<body>
		<Header />
		<main class="contact-page">
			<section class="contact-card">
				<h1>Ritika Goel</h1>
				<p>
					Ritika is an embedded systems engineer who likes to build playful hardware for kids
					and families. Originally starting her journey in hardware at the University of
					Pennsylvania, she has spent the last decade designing and optimizing consumer electronics
					at Apple and Meta. Today, TikaTiles is engineered from her personal lab in
					Orange County, California, where she lives with her husband and their 8-year-old
					daughter.
				</p>
				<div class="contact-links">
					<a href="https://www.linkedin.com/in/ritikagoel23/" target="_blank">LinkedIn</a>
					<a href="mailto:info@tikatiles.com">Email: info@tikatiles.com</a>
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	.contact-page {
		display: grid;
		place-items: center;
		min-height: calc(100vh - 220px);
	}

	.contact-card {
		width: min(760px, 100%);
		padding: clamp(1.5rem, 4vw, 3rem);
		border: 1px solid var(--line);
		border-radius: 8px;
		background: var(--surface-raised);
		box-shadow: var(--box-shadow);
	}

	.contact-card h1 {
		margin-bottom: 1rem;
		font-size: clamp(2.25rem, 6vw, 4.25rem);
		line-height: 1;
	}

	.eyebrow {
		margin: 0 0 0.75rem;
		color: var(--accent);
		font-size: 0.78rem;
		font-weight: 800;
		letter-spacing: 0.08em;
		text-transform: uppercase;
	}

	.contact-card p {
		color: rgb(var(--gray-dark));
		text-indent: 0;
	}

	.contact-links {
		display: flex;
		flex-wrap: wrap;
		gap: 0.8rem;
		margin-top: 1.5rem;
	}

	.contact-links a {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-height: 42px;
		padding: 0 1rem;
		border: 1px solid rgb(var(--black));
		border-radius: 999px;
		background: rgb(var(--black));
		color: var(--page-bg);
		font-weight: 800;
		text-decoration: none;
	}

	.contact-links a:hover {
		color: var(--page-bg);
	}
</style>
