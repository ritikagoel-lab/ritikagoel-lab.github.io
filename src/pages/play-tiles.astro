---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE } from '../consts';
import '../styles/play-tiles.css';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title={`Games | ${SITE_TITLE}`}
			description="A playable TikaTiles simulator for testing tactile learning games."
		/>
	</head>
	<body>
		<Header />
		<main class="tiles-page">
			<section class="tiles-intro">
				<h1>Games</h1>
				<p>
					Try early versions of the tile games here. The simulator uses the same idea as the
					physical toy: place tiles on the board, then play games that react to layout and touch.
				</p>
			</section>
			<section class="app-shell">
				<section class="board-panel" aria-label="TikaTiles simulator">
					<header class="topbar">
						<div>
							<h1>Play with tiles</h1>
						</div>
						<div class="mode-tabs" role="tablist" aria-label="Game mode">
							<button class="mode-tab active" type="button" data-mode="whack">Whack-a-Mole</button>
							<button class="mode-tab" type="button" data-mode="equation">Equation</button>
							<button class="mode-tab" type="button" data-mode="memory">Memory</button>
							<button class="mode-tab" type="button" data-mode="puzzle">Puzzle</button>
						</div>
					</header>

					<section class="game-instructions" aria-label="Game instructions">
						<div>
							<p class="step-label">Current Game</p>
							<h2 id="gameName">Whack-a-Mole</h2>
							<p id="setupInstructions" class="setup-instructions"></p>
						</div>
						<div class="setup-actions">
							<label id="memoryControls" class="setup-select hidden">
								Tiles
								<select id="memoryTileCount">
									<option value="4">4</option>
									<option value="8">8</option>
									<option value="12">12</option>
									<option value="16" selected>16</option>
								</select>
							</label>
							<label id="memorySpeedControls" class="setup-select hidden">
								Mode
								<select id="memorySpeedMode">
									<option value="regular" selected>Regular</option>
									<option value="fast">Challenge</option>
								</select>
							</label>
							<label id="puzzleDifficultyControls" class="setup-select hidden">
								Level
								<select id="puzzleDifficulty">
									<option value="easy">Easy</option>
									<option value="medium" selected>Medium</option>
									<option value="difficult">Difficult</option>
								</select>
							</label>
							<label id="puzzleControls" class="setup-select hidden">
								Pieces
								<select id="puzzleTileCount">
									<option value="4">4</option>
									<option value="9" selected>9</option>
								</select>
							</label>
							<button class="small-button hidden" type="button" id="puzzleHint">Hint</button>
							<button class="small-button hidden" type="button" id="puzzleAutoSolve">Auto Solve</button>
							<button class="primary-button" type="button" id="startGame">Start Game</button>
							<button class="check-button hidden" type="button" id="checkGame">Check Answer</button>
						</div>
					</section>
					<section id="puzzleHintPanel" class="puzzle-hint-panel hidden" aria-label="Puzzle hint"></section>

					<section class="quick-score" aria-label="Current game score">
						<div>
							<span class="metric-label" id="quickMetricOneLabel">Tiles</span>
							<strong id="quickTileCount">0</strong>
						</div>
						<div>
							<span class="metric-label" id="quickMetricTwoLabel">Time</span>
							<strong id="quickLinkCount">0</strong>
						</div>
						<div>
							<span class="metric-label" id="quickMetricThreeLabel">Score</span>
							<strong id="quickScoreValue">0</strong>
						</div>
					</section>

					<div class="play-area">
						<section class="pack-panel" aria-label="Tile pack">
							<div class="area-title">Tile Pack</div>
							<div class="tray" aria-label="Available tiles"></div>
						</section>
						<section class="board-area" aria-label="Tile board area">
							<div class="area-title">Tile Board</div>
							<div id="equationAnswerPanel" class="equation-answer-panel hidden" aria-label="Equation answer entry">
								<div>
									<strong>Answer</strong>
									<span>Drag digits into the numbered slots, or type the answer here.</span>
								</div>
								<label>
									Type answer
									<input id="equationAnswerInput" type="text" inputmode="numeric" autocomplete="off" maxlength="3" placeholder="12" />
								</label>
								<button class="check-button" type="button" id="equationCheckBoard">Check Answer</button>
							</div>
							<div class="grid-wrap">
								<div class="grid" aria-label="Tile board"></div>
							</div>
						</section>
					</div>
				</section>

				<aside class="side-panel">
					<section class="status-panel" aria-label="Game status">
						<div class="panel-title-row">
							<h2 id="modeTitle">Equation Builder</h2>
							<button class="small-button" type="button" id="resetBoard">Reset</button>
						</div>
						<p id="modePrompt" class="prompt"></p>
						<div class="metric-row">
							<div>
								<span class="metric-label" id="metricOneLabel">Tiles</span>
								<strong id="tileCount">0</strong>
							</div>
							<div>
								<span class="metric-label" id="metricTwoLabel">Links</span>
								<strong id="linkCount">0</strong>
							</div>
							<div>
								<span class="metric-label" id="metricThreeLabel">Score</span>
								<strong id="scoreValue">0</strong>
							</div>
						</div>
					</section>

					<section class="graph-panel" aria-label="Detected tile graph">
						<h2>Detected Graph</h2>
						<div id="graphList" class="graph-list"></div>
					</section>

					<section class="interest-panel" aria-label="Interest">
						<h2>Playtest Signal</h2>
						<label>
							I am a
							<select id="audienceRole">
								<option>Parent</option>
								<option>Teacher</option>
								<option>Kid</option>
								<option>Maker</option>
							</select>
						</label>
						<label>
							Most interesting game
							<select id="favoriteMode">
								<option>Whack-a-Mole</option>
								<option>Equation Builder</option>
								<option>Memory Match</option>
								<option>Puzzle</option>
							</select>
						</label>
						<label>
							Interest level
							<input id="interestLevel" type="range" min="1" max="5" value="3" />
						</label>
						<label>
							Email
							<input id="email" type="email" placeholder="optional" />
						</label>
						<button class="primary-button" type="button" id="saveSignal">Save Interest</button>
						<p id="saveStatus" class="save-status"></p>
					</section>
				</aside>
			</section>
		</main>
		<Footer />
		<script type="module" is:inline src="/scripts/play-tiles.js?v=17"></script>
	</body>
</html>
