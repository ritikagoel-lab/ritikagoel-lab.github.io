---
import type { HTMLAttributes } from 'astro/types';

type Props = HTMLAttributes<'a'>;

const { href, class: className, ...props } = Astro.props;
const normalizePath = (path: string | undefined) => {
	if (!path) return '/';
	const normalizedPath = path.startsWith('/') ? path : `/${path}`;
	return normalizedPath.length > 1 ? normalizedPath.replace(/\/$/, '') : normalizedPath;
};
const pathname = normalizePath(Astro.url.pathname.replace(import.meta.env.BASE_URL, ''));
const subpath = pathname.match(/[^\/]+/g);
const normalizedHref = normalizePath(href);
const isActive = normalizedHref === pathname || normalizedHref === '/' + (subpath?.[0] || '');
---

<a href={href} class:list={[className, { active: isActive }]} {...props}>
	<slot />
</a>
<style>
	a {
		display: inline-block;
		text-decoration: none;
	}
	a.active {
		font-weight: bolder;
		text-decoration: underline;
	}
</style>
